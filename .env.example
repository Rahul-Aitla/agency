# Email credentials (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Inbound email webhook secret (optional)
WEBHOOK_SECRET=your-webhook-secret

# Groq (replaces OpenAI — uses OpenAI-compatible API, models like llama-3.3-70b-versatile, mixtral-8x7b-32768)
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Server
PORT=3000

# Team routing — emails for internal notifications
PRIYA_EMAIL=priya@agency.com
RIYA_EMAIL=riya@agency.com
SAMEER_EMAIL=sameer@agency.com

# Tunnel (set to 'true' to auto-expose via ngrok; get token at https://dashboard.ngrok.com)
ENABLE_TUNNEL=false
NGROK_AUTHTOKEN=your-ngrok-token
